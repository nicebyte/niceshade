{
    float2 out_var_ATTRIBUTE0 [[user(locn0)]];
    float4 gl_Position [[position]];
};

vertex VSMain_out VSMain(constant type_ConstantBuffer_pc& buf0 [[buffer(0)]], constant type_PushConstant_pc& pcbuf [[buffer(2)]], uint gl_VertexIndex [[vertex_id]])
{
    VSMain_out out = {};
    uint _48 = gl_VertexIndex % 3u;
    float4 _51 = _42[_48] * 1.0;
    float2 _60 = _51.xy * (pcbuf.scale * buf0.scale);
    out.gl_Position = float4(_60.x, _60.y, _51.z, _51.w);
    out.out_var_ATTRIBUTE0 = _43[_48];
    return out;
}

