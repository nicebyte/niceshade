constant spvUnsafeArray<float4, 3> _42 = spvUnsafeArray<float4, 3>({ float4(-1.0, -1.0, 0.0, 1.0), float4(3.0, -1.0, 0.0, 1.0), float4(-1.0, 3.0, 0.0, 1.0) });
constant spvUnsafeArray<float2, 3> _43 = spvUnsafeArray<float2, 3>({ float2(0.0), float2(2.0, 0.0), float2(0.0, 2.0) });

